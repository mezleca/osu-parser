{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "declaration": true,
        "outDir": "dist",
        "rootDir": "ts",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true
    },
    "include": ["ts/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
