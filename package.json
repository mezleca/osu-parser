        "prebuilds/"
    ],
    "devDependencies": {
        "@types/node": "^24.10.4",
        "bun-types": "^1.3.9",
        "cmake-js": "^7.4.0",
        "node-addon-api": "^8.5.0",
        "prettier": "^3.6.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "node-gyp-build": "^4.8.4"
    }
