{
    "name": "@rel-packages/osu-parser",
    "version": "2.3.1",
    "description": "osu parser",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "commonjs",
    "scripts": {
        "update:patch": "npm version patch && git push --follow-tags",
        "update:minor": "npm version minor && git push --follow-tags",
        "update:major": "npm version major && git push --follow-tags",
        "prepublishOnly": "npm run compile:tsc && mkdir -p lib",
        "compile:native": "bun scripts/build.ts native",
        "compile:tsc": "tsc",
        "build": "bun scripts/build.ts native && tsc",
        "format": "prettier --write . --ignore-unknown",
        "format:clang": "clang-format -i $(rg --files -g '*.{h,hpp,cpp,cc,cxx}' src)",
        "test": "bun run build && bun test",
        "pretest": "bun run format"
    },
    "files": [
        "dist/index.js",
        "dist/index.d.ts",
        "dist/lib/bindings.js",
        "dist/lib/bindings.d.ts",
        "dist/types/types.js",
        "dist/types/types.d.ts",
        "prebuilds/"
    ],
    "devDependencies": {
        "@types/node": "^22.0.0",
        "bun-types": "1.3.9",
        "cmake-js": "^7.4.0",
        "node-addon-api": "^8.5.0",
        "prettier": "^3.6.2",
        "typescript": "^5.9.3"
    },
    "dependencies": {
        "node-gyp-build": "^4.8.4"
    },
    "keywords": [
        "osu",
        "beatmap",
        "parser",
        "native"
    ],
    "author": "mezleca",
    "license": "ISC",
    "repository": {
        "url": "git+https://github.com/mezleca/osu-parser.git"
    }
}
