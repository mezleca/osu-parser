{
    "name": "@rel-packages/osu-parser-core",
    "version": "0.1.0",
    "description": "osu parser core",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "commonjs",
    "scripts": {
        "compile:native": "bun scripts/build.ts native",
        "compile:tsc": "tsc",
